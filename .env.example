# Copy this file to .env and edit values before production use.

# Forge/Minecraft Java runtime image.
# 1.20.1 Forge: eclipse-temurin:17-jre-jammy
# 1.21.x Forge: eclipse-temurin:21-jre-jammy
JAVA_IMAGE=eclipse-temurin:17-jre-jammy

CONTAINER_NAME=mc-forge
MC_PORT=25565
MEM_LIMIT=6g
TZ=Asia/Seoul

EULA=TRUE
JVM_XMS=1G
JVM_XMX=4G
JVM_ARGS=-XX:+UseG1GC

ENABLE_RCON=TRUE
RCON_PORT=25575
RCON_PASSWORD=change-this-rcon-password
